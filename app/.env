# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# https://symfony.com/doc/current/configuration/secrets.html
#
# Run "composer dump-env prod" to compile .env files for production use (requires symfony/flex >=1.2).
# https://symfony.com/doc/current/best_practices.html#use-environment-variables-for-infrastructure-configuration

###> symfony/framework-bundle ###
APP_ENV=dev
# Dev-only secret; override via .env.local / real env in production.
APP_SECRET=e41dc0d4a1f2c9b7dev0nly5ecret0000
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> symfony/mailer ###
# Local dev uses Mailpit from compose (set there as a real env var).
# For production point this to your SMTP provider, e.g.:
# MAILER_DSN=smtp://user:pass@smtp.example.com:587
MAILER_DSN=null://null
###< symfony/mailer ###

###> app: contact form ###
MAIL_FROM=no-reply@developer-landing.local
MAIL_FROM_NAME="Developer Landing"
# Where owner notifications go — replace with your real address.
MAIL_OWNER=owner@example.com
###< app: contact form ###

###> app: rate limiting ###
# Sliding window per client IP for POST /api/contact.
RATE_LIMIT_CONTACT_LIMIT=5
RATE_LIMIT_CONTACT_INTERVAL='15 minutes'
###< app: rate limiting ###

###> app: AI integration ###
# Which provider to use: auto | gemini | anthropic | openai | groq | ollama | off
# "auto" tries every configured provider in priority order
# (gemini -> groq -> openai -> anthropic -> ollama), then falls back to the
# built-in keyword heuristic, so the service works even with no keys at all.
# Put real keys in .env.local (never commit them).
AI_PROVIDER=auto
AI_TIMEOUT_SECONDS=12

# Google Gemini — free key: https://aistudio.google.com/apikey
# NB: pinned models get retired for new accounts (gemini-2.5-flash returns 404
# "no longer available to new users") — aliases always track a live model.
# The lite alias has the largest free-tier quota (flash previews run out of
# daily quota fast and start returning 429).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest

# Anthropic Claude — https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Groq (free tier) — https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Local Ollama (free, offline): `ollama pull llama3.2`, then set e.g.
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3.2
###< app: AI integration ###

