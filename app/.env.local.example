# Copy to .env.local (gitignored) and fill in the secrets you have.
# Any ONE provider key below is enough — AI_PROVIDER=auto picks it up.

###> AI providers ###
# Google Gemini — free key in 1 minute, no card: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq — free tier: https://console.groq.com/keys
GROQ_API_KEY=

# Anthropic Claude (paid): https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI (paid): https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Local Ollama (free, offline). On the host: `ollama pull llama3.2`, then:
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
###< AI providers ###

###> Mail ###
# Local dev already delivers to Mailpit (http://localhost:8025) via compose.
# For real delivery set your SMTP DSN and owner address:
# MAILER_DSN=smtp://user:pass@smtp.example.com:587
MAIL_OWNER=owner@example.com
###< Mail ###
